# ============================================================
# Variables d'environnement — Gestion des Clubs
# À configurer dans l'onglet "Environnement" de Dokploy
# ============================================================

# --- Base de données PostgreSQL ---
DB_USER=admin
DB_PASSWORD=MotDePasseTresSecurise2026!
DB_NAME=gestion_clubs

# --- Sécurité JWT (générer une clé aléatoire longue) ---
JWT_SECRET=ChangezCetteCleParUneValeurAleatoireLongueEtUnique_64chars
SYNC_SECRET=ChangezCetteCleDeSync_AleatoireLongueEtUnique_64chars

# --- Domaine (utilisé par Traefik pour le certificat SSL) ---
DOMAIN=clubs.votre-domaine.fr
